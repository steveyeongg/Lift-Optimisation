{
  "name": "liftopt",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "LiftOpt — Intelligent Elevator Traffic Simulator for residential condominiums.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:single": "tsc -b && LIFTOPT_SINGLEFILE=1 vite build && node scripts/finalize-single.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^2.0.3"
  }
}
